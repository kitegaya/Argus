pipeline {
    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        DYNAMODB_TABLE = 'argus-incidents-eslam'
        S3_BUCKET = 'argus-reports-eslam'
        // If you have these as Jenkins credentials, uncomment and use:
        // GROQ_API_KEY = credentials('groq-api-key')
        // SLACK_WEBHOOK_URL = credentials('slack-webhook-url')
        // Otherwise, set them as global environment variables in Jenkins
    }

    agent any

    parameters {
        string(name: 'ALERT_PAYLOAD', defaultValue: '{}', description: 'Alert from Alertmanager')
    }

    stages {
        stage('Detect') {
            steps {
                script {
                    echo "Alert received: ${params.ALERT_PAYLOAD}"
                }
            }
        }

        stage('Classify') {
            steps {
                sh """
                    python3 scripts/classify_incident.py \\
                        --alert '${params.ALERT_PAYLOAD}' \\
                        --output classification.json
                """
                script {
                    env.SEVERITY = sh(script: "jq -r .severity classification.json", returnStdout: true).trim()
                    env.PLAYBOOK = sh(script: "jq -r .playbook classification.json", returnStdout: true).trim()
                    echo "Severity: ${env.SEVERITY} | Playbook: ${env.PLAYBOOK}"
                }
            }
        }

        stage('Approval Gate') {
            when { expression { env.PLAYBOOK == 'unknown' } }
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    input message: 'Unknown incident type. Review classification.json and approve or abort.'
                }
            }
        }

        stage('Remediate') {
            when { expression { env.PLAYBOOK != 'unknown' } }
            steps {
                sh "ansible-playbook ansible/playbooks/${env.PLAYBOOK}.yml"
            }
        }

        stage('Document') {
            steps {
                sh """
                    python3 scripts/generate_postmortem.py \\
                        --classification classification.json \\
                        --output postmortem.json
                """
            }
        }

        stage('Store & Notify') {
            steps {
                sh 'python3 scripts/store_incident.py --postmortem postmortem.json'
                sh 'python3 scripts/notify_slack.py --postmortem postmortem.json'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'classification.json,postmortem.json', allowEmptyArchive: true
        }
    }
}
